# CADE Voice Core — Environment Configuration
# Copy to .env and adjust values for your deployment.

# ====== LLM Mode ======
# CLOUD: use cloud API (DeepSeek, etc.)
# LOCAL: use local llama-server / Ollama / any OpenAI-compatible endpoint
CADE_MODE=LOCAL

# ====== Robot Identity ======
CADE_ROBOT_NAME=LARA

# ====== Cloud LLM (CADE_MODE=CLOUD) ======
CADE_CLOUD_BASE_URL=https://api.deepseek.com
CADE_CLOUD_API_KEY=your-api-key-here
CADE_CLOUD_MODEL=deepseek-chat

# ====== Local LLM (CADE_MODE=LOCAL) ======
# Default points to llama-server running Qwen3.5-9B Q8
CADE_LOCAL_BASE_URL=http://127.0.0.1:8080/v1
CADE_LOCAL_API_KEY=not-needed
CADE_LOCAL_MODEL=qwen3.5-9b-q8-local

# ====== Generation Settings ======
CADE_TEMPERATURE=0.2
CADE_MAX_TOKENS=256
CADE_TIMEOUT=60

# ====== Voice ======
CADE_VOICE_LANGUAGE=en
CADE_ECHO_SUPPRESS_MS=300
CADE_LOG_LEVEL=INFO
CADE_LOG_FILE=logs/robot.log

# ====== Audio Devices ======
# "default" uses system default; set to a device name or index to override
CADE_INPUT_DEVICE=default
CADE_OUTPUT_DEVICE=default
# PipeWire/PulseAudio source for virtual audio devices (e.g. NoMachine).
# When set, ASR captures via parec instead of sounddevice, enabling capture
# from virtual PipeWire sources that sounddevice cannot see.
# Example: CADE_INPUT_SOURCE=nx_remapped_out
#CADE_INPUT_SOURCE=nx_remapped_out

# ====== ASR ======
CADE_ASR_PROVIDER=cpu
CADE_ASR_MODEL_DIR=/home/pinggu/audio/models/asr/sherpa-onnx-nemotron-speech-streaming-en-0.6b-560ms-int8-2026-04-25
CADE_ASR_MODEL_TYPE=streaming_nemotron
CADE_VAD_MODEL=/home/pinggu/audio/models/asr/silero_vad.onnx

# ====== ASR Fallback ======
# If primary model fails to load, fall back to this model
CADE_ASR_FALLBACK_MODEL_TYPE=streaming_zipformer
CADE_ASR_FALLBACK_MODEL_DIR=/home/pinggu/audio/models/asr/sherpa-onnx-streaming-zipformer-en-20M-2023-02-17-mobile

# ====== TTS ======
CADE_TTS_PROVIDER=cpu
CADE_TTS_NUM_THREADS=2
CADE_TTS_SPEED=1.05
CADE_TTS_SID=0
CADE_TTS_ROUTER_ENABLED=true
CADE_TTS_DEFAULT_BACKEND=kokoro
CADE_TTS_FAST_BACKEND=piper
CADE_TTS_FALLBACK_BACKEND=vits
CADE_TTS_MODEL_DIR=/home/pinggu/audio/models/tts/vits-piper-en_US-libritts_r-medium-int8
CADE_TTS_KOKORO_MODEL_DIR=/home/pinggu/audio/models/tts/kokoro-en-v0_19
CADE_TTS_PIPER_MODEL_DIR=/home/pinggu/audio/models/tts/vits-piper-en_US-lessac-medium
CADE_TTS_VITS_MODEL_DIR=/home/pinggu/audio/models/tts/vits-piper-en_US-libritts_r-medium-int8
CADE_TTS_CACHE_ENABLED=true
CADE_TTS_CACHE_DIR=/home/pinggu/.cache/cade/tts
CADE_TTS_PREWARM_ENABLED=true
CADE_TTS_TEXT_NORMALIZE=true
CADE_TTS_CHUNKING_ENABLED=true
CADE_TTS_MIN_CHUNK_CHARS=20
CADE_TTS_MAX_CHUNK_CHARS=160
CADE_TTS_PLAYBACK_BACKEND=sounddevice_stream
CADE_TTS_USE_PAPLAY_FALLBACK=true
CADE_BARGE_IN_ENABLED=false
CADE_ECHO_SUPPRESS_AFTER_MS=500

# ====== Ordering Sub-FSM ======
CADE_ORDER_BASE_DIR=data/orders
CADE_ORDER_INPUT_MODE=both
# CADE_ORDER_FOOD_ALIASES={"water":["water","bottle of water"],"coke":["coke","cola"]}
# CADE_ORDER_FOOD_ALIASES_FILE=/path/to/food_aliases.json
CADE_ORDER_ASK_PROMPT=What would you like to order?
CADE_ORDER_REPEAT_INSTRUCTION=Repeat the order and ask the customer whether it is correct.
CADE_ORDER_LISTEN_RETRY_PROMPT=Sorry, I did not catch your order. Please tell me your order again.
CADE_ORDER_FIX_MISSING_PROMPT=Sorry, I didn't catch the changes. Please tell me your updated order.
CADE_ORDER_CHECK_RETRY_PROMPT=Please tell me if the order is correct, or say your updated order.
CADE_ORDER_FINISH_TEMPLATE=OK I'll get {foods} for you
CADE_ORDER_DEDUP_WINDOW_SEC=1.5
CADE_ORDER_LLM_MAX_RETRIES=3
CADE_ORDER_ID_PROPOSAL_TIMEOUT_SEC=5.0
CADE_ORDER_RULE_PARSE_ENABLED=true
CADE_ORDER_RULE_PARSE_THRESHOLD=0.90
CADE_ORDER_CONFIRM_RULE_THRESHOLD=0.90
CADE_ORDER_LLM_CANDIDATE_TOP_K=12
CADE_ORDER_LISTEN_MAX_RETRIES=5
CADE_ORDER_CHECK_MAX_RETRIES=5
CADE_ORDER_EMPTY_INPUT_MAX=3
CADE_ORDER_MAX_QTY_PER_ITEM=20
CADE_ORDER_MAX_TOTAL_QTY=99

# ====== ZeroMQ ======
CADE_ZMQ_PUB_BIND=tcp://0.0.0.0:5555
CADE_ZMQ_ROUTER_BIND=tcp://0.0.0.0:5556
CADE_ZMQ_HEARTBEAT_SEC=2.0
