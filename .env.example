# CADE Voice Core — Environment Configuration
# Copy to .env and adjust values for your deployment.

# ====== LLM Mode ======
# CLOUD: use cloud API (DeepSeek, etc.)
# LOCAL: use local Ollama
CADE_MODE=LOCAL

# ====== Robot Identity ======
CADE_ROBOT_NAME=LARA

# ====== Cloud LLM (CADE_MODE=CLOUD) ======
CADE_CLOUD_BASE_URL=https://api.deepseek.com
CADE_CLOUD_API_KEY=your-api-key-here
CADE_CLOUD_MODEL=deepseek-chat

# ====== Local LLM (CADE_MODE=LOCAL) ======
CADE_LOCAL_BASE_URL=http://localhost:11434/v1
CADE_LOCAL_API_KEY=ollama
CADE_LOCAL_MODEL=qwen3:8b

# ====== Generation Settings ======
CADE_TEMPERATURE=0.7
CADE_MAX_TOKENS=512
CADE_TIMEOUT=30
